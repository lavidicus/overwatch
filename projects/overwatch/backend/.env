# Overwatch Backend Environment Variables (Development - SQLite)

# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── Database ───
DATABASE_URL="file:./dev.db?socket_timeout=10"
PRISMA_SCHEMA="prisma/schema.sqlite.prisma"

# ─── Redis (BullMQ) ───
REDIS_URL="redis://localhost:6379"

# ─── Authentication ───
JWT_SECRET="overwatch-dev-jwt-secret-change-in-production-abc123"
JWT_EXPIRY="8h"
BCRYPT_ROUNDS=10

# ─── Encryption ───
ENCRYPTION_MASTER_KEY="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
ENCRYPTION_KEY_SOURCE="ENV"

# ─── CORS ───
CORS_ORIGIN="http://localhost:5173"

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# ─── Socket.io ───
SOCKET_CORS_ORIGIN="http://localhost:5173"

# ─── Logging ───
LOG_LEVEL="debug"
