# Overwatch Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ───
PORT=3000
NODE_ENV=development

# ─── Database ───
# PostgreSQL (production)
DATABASE_URL="postgresql://user:password@localhost:5432/overwatch?schema=public"

# SQLite (development pilot)
# DATABASE_URL="file:./dev.db?socket_timeout=10"

# ─── Redis (BullMQ) ───
REDIS_URL="redis://localhost:6379"

# ─── Authentication ───
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="8h"
BCRYPT_ROUNDS=12

# ─── Encryption ───
# Master key for envelope encryption (32 bytes base64-encoded for AES-256)
ENCRYPTION_MASTER_KEY="your-32-byte-base64-encoded-master-key"
ENCRYPTION_KEY_SOURCE="ENV"  # ENV, AWS_KMS, GCP_KMS, VAULT, IMPORTED

# KMS/Vault configuration (if not using ENV)
# AWS_KMS_KEY_ID="arn:aws:kms:region:account:key/key-id"
# GCP_KMS_KEY_ID="projects/project-id/locations/global/keyRings/keyring/cryptoKeys/key"
# VAULT_URL="https://vault.example.com"
# VAULT_TOKEN="your-vault-token"

# ─── CORS ───
CORS_ORIGIN="http://localhost:5173"

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # per window
AUTH_RATE_LIMIT_MAX=5  # failed login attempts per IP

# ─── Socket.io ───
SOCKET_CORS_ORIGIN="http://localhost:5173"

# ─── Logging ───
LOG_LEVEL="info"  # debug, info, warn, error

# ─── File Uploads ───
MAX_FILE_SIZE_MB=50
UPLOAD_DIR="./uploads"

# ─── Optional: External Services ───
# Hugging Face API (for model downloads)
# HF_API_TOKEN="your-hf-token"

# WhichLLM CLI path
# WHATLLM_PATH="/usr/local/bin/whichllm"
