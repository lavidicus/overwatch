# CertForge Configuration

# API Server
API_HOST=0.0.0.0
API_PORT=5000

# Docker
DOCKER_HOST=unix:///var/run/docker.sock

# CertForge paths
CERTFORGE_ROOT=/opt/certforge
ROOT_CA_PATH=${CERTFORGE_ROOT}/root-ca
INTERMEDIATE_CA_PATH=${CERTFORGE_ROOT}/intermediate-ca

# Default certificate settings
DEFAULT_CERT_DAYS=365
DEFAULT_KEY_SIZE=2048
